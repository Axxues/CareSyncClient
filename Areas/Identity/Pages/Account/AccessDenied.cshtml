@page
@model AccessDeniedModel
@{
    Layout = "_AccessDeniedLayout";
    ViewData["Title"] = "Access denied";
}

<div class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-70">
    <div class="parallax-blob absolute top-[-10%] right-[-5%] w-[500px] h-[500px] bg-rose-200/50 rounded-full mix-blend-multiply filter blur-[80px] animate-blob"
         :style="`transform: translate(${(mouseX - window.innerWidth/2) * -0.04}px, ${(mouseY - window.innerHeight/2) * -0.04}px)`">
    </div>
    <div class="parallax-blob absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] bg-red-100/60 rounded-full mix-blend-multiply filter blur-[80px] animate-blob animation-delay-2000"
         :style="`transform: translate(${(mouseX - window.innerWidth/2) * 0.03}px, ${(mouseY - window.innerHeight/2) * 0.03}px)`">
    </div>
</div>

<div class="w-full max-w-[420px] relative z-20 bg-white/95 backdrop-blur-xl p-8 sm:p-10 rounded-[1.5rem] shadow-[0_20px_60px_rgba(0,0,0,0.05)] border border-white/60 text-center">

    <div class="stagger-1 mb-6">
        <div class="relative inline-block hover-shake cursor-not-allowed">
            <div class="absolute inset-0 bg-red-100 rounded-full animate-ping opacity-40"></div>
            <div class="relative w-24 h-24 sm:w-28 sm:h-28 bg-gradient-to-br from-red-50 to-red-100 rounded-full flex items-center justify-center border border-red-200 shadow-inner">
                <svg class="w-10 h-10 sm:w-12 sm:h-12 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
            </div>
        </div>
    </div>

    <div class="stagger-2 mb-8">
        <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-900 mb-3 tracking-tight drop-shadow-sm">Access Restricted</h1>
        <p class="text-slate-500 text-[14px] sm:text-base leading-relaxed font-medium">
            Your current account role lacks the administrative privileges required to view this directory.
        </p>
    </div>

    <div class="stagger-2 inline-flex items-center gap-2.5 px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-slate-600 text-[13px] sm:text-sm font-bold mb-8 shadow-sm">
        <svg class="w-4 h-4 text-red-500 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        Auto-redirecting in <span x-text="count" class="text-red-600 font-extrabold w-4 text-center"></span>s
    </div>

    <div class="stagger-3 flex flex-col sm:flex-row gap-3">
        <a asp-controller="Home" asp-action="Index" class="flex-1 bg-slate-900 hover:bg-slate-800 text-white font-bold text-[14px] sm:text-base py-3 rounded-[14px] transition-all shadow-[0_8px_15px_rgba(0,0,0,0.15)] hover:shadow-[0_12px_25px_rgba(0,0,0,0.2)] active:scale-95 flex items-center justify-center gap-2">
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Go Back
        </a>

        <a asp-area="Identity" asp-page="/Account/Login" class="flex-1 bg-white hover:bg-slate-50 border-2 border-slate-200 text-slate-700 font-bold text-[14px] sm:text-base py-3 rounded-[14px] transition-all active:scale-95 hover:border-slate-300">
            Log In as other role
        </a>
    </div>

</div>
