@page
@model RegisterConfirmationModel
@{
    Layout = "_RegisterPendingLayout";
    ViewData["Title"] = "Register";
}

@section LayoutScripts {
    <link rel="stylesheet" href="~/assets/css/flatpickr.min.css">
    <script src="~/assets/js/flatpickr.min.js"></script>
}

<div class="max-w-md w-full">
    <div class="flex items-center justify-center gap-3 mb-10">
        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-sm border border-slate-200">
            <img src="~/assets/imgs/logo.jpg" alt="Logo" class="w-8 h-8 object-contain">
        </div>
        <span class="font-extrabold text-3xl text-slate-800 tracking-tight">CareSync<span class="text-emerald-500">.</span></span>
    </div>

    <div class="bg-white rounded-[2rem] shadow-xl shadow-slate-200/60 border border-slate-100 p-8 md:p-10 text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-2 bg-amber-400"></div>

        <div class="relative mb-8">
            <div class="w-20 h-20 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center mx-auto border-4 border-white shadow-[0_0_0_8px_rgba(245,158,11,0.1)] relative z-10">
                <svg class="w-10 h-10 animate-pulse" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
        </div>

        <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight mb-3">Registration Sent!</h1>

        <div class="space-y-4">
            <p class="text-slate-500 text-sm leading-relaxed font-medium">
                Thank you for joining <span class="text-slate-900 font-bold">CareSync Enterprise</span>. Your account request has been successfully submitted to the system.
            </p>

            <div class="bg-slate-50 rounded-2xl p-4 border border-slate-100">
                <p class="text-[13px] text-slate-600 font-semibold italic">
                    "Your account is currently <span class="text-amber-600">Pending Review</span>. Please wait for the Administrator to validate and activate your access."
                </p>
            </div>

            <p class="text-xs text-slate-400 font-medium">
                You will be able to log in once your role is confirmed.
            </p>
        </div>

        <div class="mt-10">
            <a asp-area="Identity" asp-page="/Account/Login" class="inline-flex items-center justify-center gap-2 w-full py-4 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-2xl transition-all active:scale-[0.98] shadow-lg shadow-slate-900/20">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 15l-3-3m0 0l3-3m-3 3h8M3 12a9 9 0 1118 0 9 9 0 0118 0z"></path>
                </svg>
                Return to Login
            </a>
        </div>
    </div>

    <p class="text-center mt-8 text-sm text-slate-400 font-medium">
        Need urgent access? Contact <span class="text-slate-600 font-bold underline">Admin Sarah</span>.
    </p>
</div>

@section Scripts {
    <script src="~/assets/js/main.js"></script>
}
