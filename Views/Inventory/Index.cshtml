@model InventoryDashboard

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Inventory";
}


<div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8 stagger-1">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Pharmacy Inventory</h1>
        <p class="text-slate-500 mt-1 font-medium">Manage stock levels, categories, and expirations.</p>
    </div>
    <div class="flex gap-3">
        <a asp-controller="Inventory" asp-action="Dispense" class="inline-flex items-center justify-center gap-2 bg-white border-2 border-slate-200 hover:border-slate-300 text-slate-700 font-bold py-2.5 px-5 rounded-xl transition-all active:scale-95">
            <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
            Dispense
        </a>
        <a asp-controller="Inventory" asp-action="DispenseLog" class="inline-flex items-center justify-center gap-2 bg-white border-2 border-slate-200 hover:border-slate-300 text-slate-700 font-bold py-2.5 px-5 rounded-xl transition-all active:scale-95">
            <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
            Dispense Log
        </a>
        @if (User.IsInRole("Admin") || User.IsInRole("Encoder"))
        {
            <a asp-controller="Inventory" asp-action="Create" class="inline-flex items-center justify-center gap-2 bg-slate-900 hover:bg-slate-800 text-white font-bold py-2.5 px-5 rounded-xl shadow-lg transition-all active:scale-95">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
                Add Item
            </a>
        }
        
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8 stagger-2">
    <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
        </div>
        <div>
            <p class="text-sm font-bold text-slate-500 uppercase tracking-wider">Total Items</p>
            <h3 class="text-2xl font-extrabold text-slate-900">@Model.TotalItemsCount</h3>
        </div>
    </div>

    <div class="bg-white p-5 rounded-2xl shadow-sm border border-red-100 bg-red-50/30 flex items-center gap-4 relative overflow-hidden">
        <div class="absolute right-0 top-0 w-2 h-full bg-red-500"></div>
        <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center text-red-600 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <div>
            <p class="text-sm font-bold text-red-500 uppercase tracking-wider">Low Stock</p>
            <h3 class="text-2xl font-extrabold text-slate-900">@Model.LowStockCount <span class="text-sm font-bold text-slate-500 ml-1">Items</span></h3>
        </div>
    </div>

    <div class="bg-white p-5 rounded-2xl shadow-sm border border-orange-100 bg-orange-50/30 flex items-center gap-4 relative overflow-hidden">
        <div class="absolute right-0 top-0 w-2 h-full bg-orange-500"></div>
        <div class="w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <div>
            <p class="text-sm font-bold text-orange-500 uppercase tracking-wider">Expiring Soon</p>
            <h3 class="text-2xl font-extrabold text-slate-900">@Model.ExpiringSoonCount <span class="text-sm font-bold text-slate-500 ml-1">Items</span></h3>
        </div>
    </div>
</div>

<form asp-action="Index" method="get">
    <div class="bg-white p-4 rounded-[1.25rem] shadow-sm border border-slate-200 mb-6 flex flex-col md:flex-row gap-4 stagger-3 relative z-30">
        <div class="flex-1 relative">
            <svg class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            <input name="s" type="text" value="@Model.InventoryList.SearchKeyword" placeholder="Search item name, generic name, or batch..." class="w-full pl-11 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all font-medium placeholder-slate-400">
        </div>

        <div x-data="{
            open: false,
            selected: '@(Model.InventoryList.SecondarySearchKeyword ?? "")',
            label: 'All Categories',
            options: [
                { val: '', text: 'All Categories' },
                { val: 'Antibiotics', text: 'Antibiotics' },
                { val: 'Vitamins', text: 'Vitamins & Supplements' },
                { val: 'FirstAid', text: 'First Aid' },
                { val: 'PainRelief', text: 'Pain Relief' },
                { val: 'Others', text: 'Others' }
             ],
             init() {
             const activeOption=this.options.find(o => o.val === this.selected);
                if (activeOption)
                {
                    this.label = activeOption.text;
                }
             }
            }" class="relative w-full md:w-56">
            <input name="a" type="hidden" value="@Model.InventoryList.SecondarySearchKeyword" :value="selected">
            <button type="button" x-on:click="open = !open" x-on:click.outside="open = false"
                    class="w-full py-2.5 px-4 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 transition-all text-left flex justify-between items-center h-[42px]"
                    :class="open ? 'ring-2 ring-emerald-500/20 border-emerald-500 bg-white' : ''">
                <span x-text="label"></span>
                <svg class="w-4 h-4 text-slate-400 transition-transform duration-300" :class="open ? 'rotate-180 text-emerald-500' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>

            <div x-show="open"
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="opacity-0 translate-y-2 scale-95"
                    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                    x-transition:leave="transition ease-in duration-150"
                    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                    x-transition:leave-end="opacity-0 translate-y-2 scale-95"
                    class="alpine-dropdown-menu absolute right-0 left-0 md:left-auto mt-2 md:w-64 bg-white/95 backdrop-blur-xl border border-slate-200 rounded-xl shadow-xl overflow-hidden" style="display: none;">
                <ul class="py-1">
                    <template x-for="option in options" :key="option.val">
                        <li x-on:click="selected = option.val; label = option.text; open = false"
                            class="px-4 py-2.5 text-sm cursor-pointer transition-colors flex items-center justify-between"
                            :class="selected === option.val ? 'bg-emerald-50 text-emerald-700 font-bold' : 'text-slate-600 font-medium hover:bg-slate-50 hover:text-slate-900'">
                            <span x-text="option.text"></span>
                            <svg x-show="selected === option.val" class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                        </li>
                    </template>
                </ul>
            </div>
        </div>
        <div class="relative w-full md:w-48">
            <button class="w-full flex-1 sm:flex-none h-10 px-4 inline-flex justify-center items-center border border-slate-200 rounded-lg text-sm font-bold text-slate-700 bg-white hover:bg-slate-50 transition-colors">Search</button>
        </div>
    </div>
</form>

<div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 overflow-hidden stagger-4 relative z-20">
    <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse">
            <thead class="hidden md:table-header-group">
                <tr class="bg-slate-50/80 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-100">
                    <th class="px-6 py-4 font-bold">Item Details</th>
                    <th class="px-6 py-4 font-bold">Category</th>
                    <th class="px-6 py-4 font-bold">Expiry Date</th>
                    <th class="px-6 py-4 font-bold">Stock Status</th>
                    <th class="px-6 py-4 font-bold text-center">Actions</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-slate-100 text-sm font-medium text-slate-700 flex flex-col md:table-row-group">

                @foreach(var item in Model.InventoryList.Result)
                {
                    <tr class="flex flex-col md:table-row hover:bg-slate-50 transition-colors group cursor-default p-5 md:p-0">

                        <td class="order-1 md:order-none md:px-6 md:py-4 mb-4 md:mb-0 border-b border-slate-50 md:border-none pb-4 md:pb-0">
                            <div class="flex items-center gap-4 md:gap-3">
                                <div class="w-12 h-12 md:w-10 md:h-10 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
                                    <svg class="w-6 h-6 md:w-5 md:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                                </div>
                                <div>
                                    <p class="text-slate-900 font-bold text-base md:text-sm">@item.ItemDetail.GenericName</p>
                                    <p class="text-slate-500 text-xs font-semibold md:font-normal mt-0.5">Batch: @item.BatchNumber</p>
                                </div>
                            </div>
                        </td>

                        <td class="order-3 md:order-none md:px-6 md:py-4 mb-2 md:mb-0 flex justify-between md:table-cell items-center">
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider md:hidden">Category</span>
                            <span class="text-slate-600">@item.ItemDetail.Category</span>
                        </td>

                        <td class="order-4 md:order-none md:px-6 md:py-4 mb-5 md:mb-0 flex justify-between md:table-cell items-center">
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider md:hidden">Expiry</span>
                            <span class="text-slate-600">@DateTime.Parse(item.ExpiryDate).ToString("MMMM dd, yyyy")</span>
                        </td>

                        <td class="order-2 md:order-none md:px-6 md:py-4 mb-3 md:mb-0 flex justify-between md:table-cell items-center">
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider md:hidden">Stock</span>
                            <div class="text-right md:text-left">
                                <p class="font-extrabold text-slate-900">500 <span class="font-medium text-slate-500 text-xs">tabs</span></p>
                                <span class="inline-block mt-1 px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-100 text-emerald-700">@item.InitialQuantity</span>
                            </div>
                        </td>

                        <td class="order-5 md:order-none md:px-6 md:py-4 border-t border-slate-100 md:border-none pt-4 md:pt-0">
                            <div class="flex justify-between md:justify-center items-center gap-3 md:gap-2 md:opacity-0 group-hover:opacity-100 transition-opacity">
                                @if (User.IsInRole("Admin") || User.IsInRole("Encoder"))
                                {
                                    <a asp-controller="Inventory" asp-action="Edit" asp-route-id="@item.Id" class="flex-1 md:flex-none flex justify-center items-center gap-2 p-2.5 md:p-2 bg-blue-50 text-blue-600 hover:bg-blue-100 rounded-lg transition-colors font-bold md:font-normal text-sm" title="Edit Item">
                                        <svg class="w-5 h-5 md:w-4 md:h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                        <span class="md:hidden">Edit</span>
                                    </a>
                                }
                                
                                @* <button x-on:click="showDeleteModal = true" class="flex-1 md:flex-none flex justify-center items-center gap-2 p-2.5 md:p-2 bg-red-50 text-red-600 hover:bg-red-100 rounded-lg transition-colors font-bold md:font-normal text-sm" title="Delete">
                                    <svg class="w-5 h-5 md:w-4 md:h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    <span class="md:hidden">Delete</span>
                                </button> *@
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @{
        var pageActive = "flex-1 sm:flex-none inline-flex justify-center items-center px-4 py-2 border border-slate-200 rounded-lg text-sm font-bold text-slate-700 bg-white hover:bg-slate-50 transition-colors";
        var pageInactive = "flex-1 sm:flex-none inline-flex justify-center items-center px-4 py-2 border border-slate-200 rounded-lg text-sm font-bold text-slate-400 bg-white cursor-not-allowed";
    }
    <div class="px-6 py-4 border-t border-slate-100 flex flex-col sm:flex-row items-center justify-between bg-slate-50/50 gap-4 sm:gap-0">
        <p class="text-sm text-slate-500 font-medium">Showing 1 to @Model.InventoryList.Result.Count() of @Model.InventoryList.TotalRecords patients</p>
        <div class="flex gap-2 w-full sm:w-auto">
            <a asp-route-p="@(Model.InventoryList.Page - 1)" asp-route-s="@Model.InventoryList.SearchKeyword" asp-route-a="@Model.InventoryList.SecondarySearchKeyword" class="@(Model.InventoryList.Page == 1 ? pageInactive : pageActive)">
                Prev
            </a>

            @for (var pageNumber = 1; pageNumber <= Model.InventoryList.TotalCount; pageNumber++)
            {
                if (pageNumber == Model.InventoryList.Page)
                {
                    <span class="@pageInactive">
                        @pageNumber
                    </span>
                }
                else
                {
                    <a asp-route-p="@pageNumber" asp-route-s="@Model.InventoryList.SearchKeyword" asp-route-a="@Model.InventoryList.SecondarySearchKeyword" class="@pageActive">
                        @pageNumber
                    </a>
                }
            }

            <a asp-route-p="@(Model.InventoryList.Page + 1)" asp-route-s="@Model.InventoryList.SearchKeyword" asp-route-a="@Model.InventoryList.SecondarySearchKeyword" class="@(Model.InventoryList.Page == Model.InventoryList.TotalCount ? pageInactive : pageActive)">
                Next
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <div x-show="showDeleteModal" style="display: none;" class="relative z-50">
        <div x-show="showDeleteModal" x-transition.opacity class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity"></div>
        <div class="fixed inset-0 z-10 overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div x-show="showDeleteModal" x-on:click.away ="showDeleteModal = false" x-transition class="relative transform overflow-hidden rounded-[1.5rem] bg-white text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-md border border-slate-100">
                    <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                        <div class="sm:flex sm:items-start">
                            <div class="mx-auto flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-red-100 sm:mx-0 sm:h-10 sm:w-10">
                                <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                            </div>
                            <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
                                <h3 class="text-lg font-extrabold leading-6 text-slate-900">Delete Item from Inventory</h3>
                                <div class="mt-2">
                                    <p class="text-sm text-slate-500 font-medium">Are you sure you want to delete this item? This will remove it entirely from stock tracking. <span class="font-bold text-red-500">This action cannot be undone.</span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="bg-slate-50 px-4 py-4 sm:flex sm:flex-row-reverse sm:px-6 border-t border-slate-100">
                        <button type="button" x-on:click="showDeleteModal = false" class="inline-flex w-full justify-center rounded-xl bg-red-600 px-4 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-red-700 sm:ml-3 sm:w-auto transition-colors">Delete Item</button>
                        <button type="button" x-on:click="showDeleteModal = false" class="mt-3 inline-flex w-full justify-center rounded-xl bg-white px-4 py-2.5 text-sm font-bold text-slate-700 shadow-sm border border-slate-200 hover:bg-slate-50 sm:mt-0 sm:w-auto transition-colors">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/assets/js/main.js"></script>
}
