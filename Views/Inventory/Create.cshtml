@model InventoryItemDetail

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Inventory";
}

@section LayoutScripts{
    <link rel="stylesheet" href="~/assets/css/flatpickr.min.css">
    <script src="~/assets/js/flatpickr.min.js"></script>
}

    
<div class="mb-8 stagger-1">
    <a asp-controller="Inventory" asp-action="Index" class="inline-flex items-center text-sm font-bold text-slate-400 hover:text-emerald-600 transition-colors mb-4">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Inventory
    </a>
    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Add Medicine</h1>
    <p class="text-slate-500 mt-1 font-medium">Record a new medicine or medical supply to the inventory.</p>
</div>

<form asp-action="CreateItem" method="POST" class="space-y-6 stagger-2">
    @Html.AntiForgeryToken()
    <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 p-6 sm:p-8 relative z-30">
        <h2 class="text-lg font-extrabold text-slate-900 mb-6 flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center">1</span>
            Item Identification
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="ItemName" class="block text-sm font-bold text-slate-600 mb-2">Item Name (Brand)</label>
                <input asp-for="ItemName" type="text" class="w-full px-4 py-3 rounded-xl border-[1.5px] border-slate-200 bg-slate-50 text-slate-900 font-medium focus:outline-none focus:border-emerald-500 focus:bg-white transition-colors" placeholder="e.g. Biogesic" required>
                <span asp-validation-for="ItemName" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div>
                <label asp-for="GenericName" class="block text-sm font-bold text-slate-600 mb-2">Generic Name</label>
                <input asp-for="GenericName" type="text" class="w-full px-4 py-3 rounded-xl border-[1.5px] border-slate-200 bg-slate-50 text-slate-900 font-medium focus:outline-none focus:border-emerald-500 focus:bg-white transition-colors" placeholder="e.g. Paracetamol 500mg" required>
                <span asp-validation-for="GenericName" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>

            <div x-data="{
                open: false, selected: '', label: 'Select Category...',
                options: [
                    { val: 'Antibiotics', text: 'Antibiotics' },
                    { val: 'PainRelief', text: 'Pain Relief' },
                    { val: 'Vitamins', text: 'Vitamins & Supplements' },
                    { val: 'FirstAid', text: 'First Aid & Wound Care' },
                    { val: 'Others', text: 'Others' }
                ]
            }" class="relative w-full md:col-span-2">
                <label class="block text-sm font-bold text-slate-600 mb-2">Category</label>
                <input asp-for="Category" type="hidden" x-model.fill="selected" required
                x-init="$nextTick(() => {
                if(selected) {
                let opt = options.find(o => o.val === selected);
                if(opt) label = opt.text;
                }
                })">

                <button type="button" x-on:click="open = !open" x-on:click.outside="open = false"
                        class="w-full px-4 py-3 rounded-xl border-[1.5px] border-slate-200 bg-slate-50 text-slate-900 font-medium focus:outline-none focus:border-emerald-500 transition-colors text-left flex justify-between items-center h-[46px]"
                        :class="open ? 'ring-4 ring-emerald-500/20 border-emerald-500 bg-white' : ''">
                    <span x-text="label" :class="selected === '' ? 'text-slate-400' : 'text-slate-900'"></span>
                    <svg class="w-5 h-5 transition-transform duration-300" :class="open ? 'rotate-180 text-emerald-500' : 'text-slate-400'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>

                <div x-show="open"
                        x-transition
                        class="alpine-dropdown-menu absolute left-0 right-0 mt-2 bg-white/95 backdrop-blur-xl border border-slate-200 rounded-[1rem] shadow-2xl overflow-hidden" style="display: none;">
                    <ul class="py-2">
                        <template x-for="option in options" :key="option.val">
                            <li x-on:click="selected = option.val; label = option.text; open = false"
                                class="px-5 py-3 text-sm cursor-pointer transition-colors flex items-center justify-between"
                                :class="selected === option.val ? 'bg-indigo-50 text-indigo-700 font-bold' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'">
                                <span x-text="option.text"></span>
                                <svg x-show="selected === option.val" class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                            </li>
                        </template>
                    </ul>
                </div>
                <span asp-validation-for="Category" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 p-6 sm:p-8 relative z-20">
        <h2 class="text-lg font-extrabold text-slate-900 mb-6 flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center">2</span>
            Stock Details
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="StockDetail.InitialQuantity" class="block text-sm font-bold text-slate-600 mb-2">Initial Quantity</label>
                <input asp-for="StockDetail.InitialQuantity" type="number" class="w-full px-4 py-3 rounded-xl border-[1.5px] border-slate-200 bg-slate-50 text-slate-900 font-medium focus:outline-none focus:border-emerald-500 focus:bg-white transition-colors" placeholder="e.g. 500" required>
                <span asp-validation-for="StockDetail.InitialQuantity" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div>
                <label asp-for="StockDetail.AlertLevel" class="block text-sm font-bold text-slate-600 mb-2">Reorder Alert Level</label>
                <input asp-for="StockDetail.AlertLevel" type="number" class="w-full px-4 py-3 rounded-xl border-[1.5px] border-slate-200 bg-slate-50 text-slate-900 font-medium focus:outline-none focus:border-emerald-500 focus:bg-white transition-colors" placeholder="Alert me when stock falls below..." required>
                <span asp-validation-for="StockDetail.AlertLevel" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div>
                <label asp-for="StockDetail.BatchNumber" class="block text-sm font-bold text-slate-600 mb-2">Batch Number</label>
                <input asp-for="StockDetail.BatchNumber" type="text" class="w-full px-4 py-3 rounded-xl border-[1.5px] border-slate-200 bg-slate-50 text-slate-900 font-medium focus:outline-none focus:border-emerald-500 focus:bg-white transition-colors" placeholder="e.g. B-9982" required>
                <span asp-validation-for="StockDetail.BatchNumber" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div>
                <label asp-for="StockDetail.ExpiryDate" class="block text-sm font-bold text-slate-600 mb-2">Expiry Date</label>
                <div class="relative">
                    <input asp-for="StockDetail.ExpiryDate" type="text" id="expiry-date-picker" class="w-full pl-11 pr-4 py-3 rounded-xl border-[1.5px] border-slate-200 bg-white text-slate-900 font-medium focus:outline-none focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/20 transition-all cursor-pointer" placeholder="Select Expiry Date" required readonly>
                    <svg class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-emerald-500 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
                <span asp-validation-for="StockDetail.ExpiryDate" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
        </div>
    </div>

    <div class="flex items-center justify-end gap-4 pt-4 pb-10">
        <a asp-controller="Inventory" asp-action="Index" class="px-6 py-3 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition-colors">Cancel</a>
        <button type="submit" class="px-8 py-3 rounded-xl font-bold text-white bg-emerald-600 hover:bg-emerald-700 shadow-lg shadow-emerald-500/30 hover:shadow-xl hover:shadow-emerald-500/40 hover:-translate-y-0.5 transition-all">
            Save to Inventory
        </button>
    </div>
    <p>Here: @TempData["Result"]</p>
</form>

@if (TempData["Result"] is not null)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center" x-data="{ statusModal: 'active' }" x-show="statusModal != null">

        <div x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
             class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm"
             x-on:click="statusModal = null"></div>

        <div x-transition:enter="transition ease-out duration-300 delay-75" x-transition:enter-start="opacity-0 translate-y-8 scale-95" x-transition:enter-end="opacity-100 translate-y-0 scale-100"
             x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0 scale-100" x-transition:leave-end="opacity-0 translate-y-8 scale-95"
             class="relative bg-white w-full max-w-[340px] mx-4 p-6 rounded-[1.5rem] shadow-2xl border border-slate-100 flex flex-col items-center text-center z-10">

            @if (Convert.ToString(TempData["Result"]) == "Success")
            {
                <template x-init="statusModal = 'success'"></template>
                <template x-if="statusModal === 'success'">
                    <div class="flex flex-col items-center w-full">
                        <div class="w-14 h-14 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center mb-4 border-4 border-white shadow-[0_0_0_4px_rgba(16,185,129,0.15)]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <h3 class="text-[18px] font-extrabold text-slate-900 tracking-tight mb-1.5">Record Saved!</h3>
                        <p class="text-[13px] text-slate-500 mb-6 leading-relaxed">The patient's information has been successfully registered in the system.</p>
                        <a asp-action="Index" x-on:click="statusModal = null;" class="mb-1 w-full py-3 px-4 rounded-[12px] text-[13px] font-bold text-white bg-emerald-600 hover:bg-emerald-700 shadow-[0_8px_15px_rgba(5,150,105,0.2)] transition-all focus:outline-none">
                            Back to Directory
                        </a>
                        <button asp-action="Index" x-on:click="statusModal = null;" class="w-full py-3 px-4 rounded-[12px] text-[13px] font-bold text-slate-600 bg-slate-50 hover:bg-slate-100 transition-colors focus:outline-none">
                            Add New Data
                        </button>
                    </div>
                </template>

            }
            else if (Convert.ToString(TempData["Result"]) == "Validate")
            {
                <template x-init="statusModal = 'validation'"></template>
                <template x-if="statusModal === 'validation'">
                    <div class="flex flex-col items-center w-full">
                        <div class="w-14 h-14 rounded-full bg-red-50 text-red-500 flex items-center justify-center mb-4 border-4 border-white shadow-[0_0_0_4px_rgba(239,68,68,0.15)]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        </div>
                        <h3 class="text-[18px] font-extrabold text-slate-900 tracking-tight mb-1.5">Validation Failed</h3>
                        <p class="text-[13px] text-slate-500 mb-6 leading-relaxed">Please check the form for missing or incorrect information and try again.</p>
                        <button type="button" x-on:click="statusModal = null" class="w-full py-3 px-4 rounded-[12px] text-[13px] font-bold text-slate-600 bg-slate-50 hover:bg-slate-100 transition-colors focus:outline-none">
                            Review Form
                        </button>
                    </div>
                </template>
            }
            else if (Convert.ToString(TempData["Result"]) == "Error")
            {
                <template x-init="statusModal = 'server'"></template>
                <template x-if="statusModal === 'server'">
                    <div class="flex flex-col items-center w-full">
                        <div class="w-14 h-14 rounded-full bg-amber-50 text-amber-500 flex items-center justify-center mb-4 border-4 border-white shadow-[0_0_0_4px_rgba(245,158,11,0.15)]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <h3 class="text-[18px] font-extrabold text-slate-900 tracking-tight mb-1.5">@TempData["ErrorMessage"]</h3>
                        <p class="text-[13px] text-slate-500 mb-6 leading-relaxed">We couldn't connect to the server to save the record. Please try again later.</p>
                        <button x-on:click="statusModal = null" class="w-full py-3 px-4 rounded-[12px] text-[13px] font-bold text-white bg-amber-500 hover:bg-amber-600 shadow-[0_8px_15px_rgba(245,158,11,0.2)] transition-all focus:outline-none">
                            Dismiss
                        </button>
                    </div>
                </template>
            }
        </div>
    </div>
}

@section Scripts{
    <script src="~/assets/js/main.js"></script>
}
