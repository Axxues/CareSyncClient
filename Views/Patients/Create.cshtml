@model PatientProfile

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Patients";
}

@section LayoutScripts {
    <link rel="stylesheet" href="~/assets/css/flatpickr.min.css">
    <script src="~/assets/js/flatpickr.min.js"></script>
}

<div class="mb-8 stagger-1">
    <a asp-controller="Patients" asp-action="Index" class="inline-flex items-center text-sm font-bold text-slate-400 hover:text-emerald-600 transition-colors mb-4">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Directory
    </a>
    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">New Patient Record</h1>
    <p class="text-slate-500 mt-1 font-medium">Please enter the patient's accurate details below.</p>
</div>
@* <div asp-validation-summary="All" class="text-danger">
    <span>Please fix the following errors:</span>
</div> *@
<form asp-action="CreatePatientProfileInfo" method="POST" class="space-y-6 stagger-2">
    @Html.AntiForgeryToken()
    @* Personal Information *@
    <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 p-6 sm:p-8 relative z-30">
        <h2 class="text-lg font-extrabold text-slate-900 mb-6 flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center">1</span>
            Personal Information
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="PersonalInformation.FirstName" class="form-label">First Name</label>
                <input asp-for="PersonalInformation.FirstName" type="text" class="form-input" placeholder="e.g. Maria" required>
                <span asp-validation-for="PersonalInformation.FirstName" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div>
                <label asp-for="PersonalInformation.LastName" class="form-label">Last Name</label>
                <input asp-for="PersonalInformation.LastName" type="text" class="form-input" placeholder="e.g. Dela Cruz" required>
                <span asp-validation-for="PersonalInformation.LastName" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>

            <div>
                <label asp-for="PersonalInformation.DateofBirth" class="form-label">Date of Birth</label>
                <div class="relative">
                    <input asp-for="PersonalInformation.DateofBirth" type="text" id="dob-picker" class="form-input !pl-12 bg-white" placeholder="Select a date..." required readonly>

                    <svg class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-emerald-500 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <span asp-validation-for="PersonalInformation.DateofBirth" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>

            <div x-data="{
                open: false,
                selected: '',
                label: 'Select Gender',
                options: [
                    { val: 'Male', text: 'Male' },
                    { val: 'Female', text: 'Female' }
                ]
            }" class="relative w-full">
                <label asp-for="PersonalInformation.Gender" class="form-label">Gender</label>
                <input asp-for="PersonalInformation.Gender" type="hidden" x-model.fill="selected" required
                x-init="$nextTick(() => {
                if(selected) {
                let opt = options.find(o => o.val === selected);
                if(opt) label = opt.text;
                }
                })">

                <button type="button" x-on:click="open = !open" x-on:click.outside="open = false"
                        class="form-input text-left flex justify-between items-center transition-all duration-200 outline-none h-[46px]"
                        :class="open ? 'ring-4 ring-emerald-500/20 border-emerald-500 bg-white' : ''">
                    <span x-text="label" :class="selected === '' ? 'text-slate-400' : 'text-slate-900'"></span>
                    <svg class="w-5 h-5 transition-transform duration-300" :class="open ? 'rotate-180 text-emerald-500' : 'text-slate-400'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>

                <div x-show="open"
                        x-transition:enter="transition ease-out duration-200"
                        x-transition:enter-start="opacity-0 translate-y-2 scale-95"
                        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                        x-transition:leave="transition ease-in duration-150"
                        x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                        x-transition:leave-end="opacity-0 translate-y-2 scale-95"
                        class="alpine-dropdown-menu absolute left-0 right-0 mt-2 bg-white/95 backdrop-blur-xl border border-slate-200 rounded-[1rem] shadow-2xl overflow-hidden" style="display: none;">
                    <ul class="py-2">
                        <template x-for="option in options" :key="option.val">
                            <li x-on:click="selected = option.val; label = option.text; open = false"
                                class="px-5 py-3 text-sm cursor-pointer transition-colors flex items-center justify-between"
                                :class="selected === option.val ? 'bg-emerald-50 text-emerald-700 font-bold' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'">
                                <span x-text="option.text"></span>
                                <svg x-show="selected === option.val" class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                            </li>
                        </template>
                    </ul>
                </div>
                <span asp-validation-for="PersonalInformation.Gender" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>

            <div>
                <label asp-for="PersonalInformation.ContactNumber" class="form-label">Contact Number</label>
                <input asp-for="PersonalInformation.ContactNumber" type="tel" class="form-input" placeholder="e.g. 0912 345 6789">
                <span asp-validation-for="PersonalInformation.ContactNumber" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>

            <div x-data="{
                open: false,
                selected: '',
                label: 'Select Blood Type',
                options: [
                    { val: 'A+', text: 'Type A+' }, { val: 'A-', text: 'Type A-' },
                    { val: 'B+', text: 'Type B+' }, { val: 'B-', text: 'Type B-' },
                    { val: 'AB+', text: 'Type AB+' }, { val: 'AB-', text: 'Type AB-' },
                    { val: 'O+', text: 'Type O+' }, { val: 'O-', text: 'Type O-' }
                ]
            }" class="relative w-full">
                <label asp-for="PersonalInformation.BloodType" class="form-label">Blood Type</label>
                <input asp-for="PersonalInformation.BloodType" type="hidden" x-model.fill="selected"
                x-init="$nextTick(() => {
                if(selected) {
                let opt = options.find(o => o.val === selected);
                if(opt) label = opt.text;
                }
                })">

                <button type="button" x-on:click="open = !open" x-on:click.outside="open = false"
                        class="form-input text-left flex justify-between items-center transition-all duration-200 outline-none h-[46px]"
                        :class="open ? 'ring-4 ring-emerald-500/20 border-emerald-500 bg-white' : ''">
                    <span x-text="label" :class="selected === '' ? 'text-slate-400' : 'text-slate-900'"></span>
                    <svg class="w-5 h-5 transition-transform duration-300" :class="open ? 'rotate-180 text-emerald-500' : 'text-slate-400'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>

                <div x-show="open"
                        x-transition:enter="transition ease-out duration-200"
                        x-transition:enter-start="opacity-0 translate-y-2 scale-95"
                        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                        x-transition:leave="transition ease-in duration-150"
                        x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                        x-transition:leave-end="opacity-0 translate-y-2 scale-95"
                        class="alpine-dropdown-menu absolute left-0 right-0 mt-2 bg-white/95 backdrop-blur-xl border border-slate-200 rounded-[1rem] shadow-2xl max-h-60 overflow-y-auto" style="display: none;">
                    <ul class="py-2">
                        <template x-for="option in options" :key="option.val">
                            <li x-on:click="selected = option.val; label = option.text; open = false"
                                class="px-5 py-2.5 text-sm cursor-pointer transition-colors flex items-center justify-between"
                                :class="selected === option.val ? 'bg-red-50 text-red-700 font-bold' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'">
                                <span x-text="option.text"></span>
                                <svg x-show="selected === option.val" class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                            </li>
                        </template>
                    </ul>
                </div>
                <span asp-validation-for="PersonalInformation.BloodType" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>

            <div class="md:col-span-2">
                <label asp-for="PersonalInformation.ResidentialAddress" class="form-label">Residential Address (Purok)</label>
                <input asp-for="PersonalInformation.ResidentialAddress" type="text" class="form-input" placeholder="e.g. Purok 2, Barangay Garcia, Tubao" required>
                <span asp-validation-for="PersonalInformation.ResidentialAddress" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
        </div>
    </div>

    @* Health Information *@

    <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 p-6 sm:p-8 relative z-20">
        <h2 class="text-lg font-extrabold text-slate-900 mb-6 flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center">2</span>
            Health Information
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="HealthInformation.Height" class="form-label">Height (cm)</label>
                <input asp-for="HealthInformation.Height" type="number" class="form-input" placeholder="e.g. 165">
                <span asp-validation-for="PersonalInformation.ResidentialAddress" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div>
                <label asp-for="HealthInformation.Weight" class="form-label">Weight (kg)</label>
                <input asp-for="HealthInformation.Weight" type="number" class="form-input" placeholder="e.g. 62">
                <span asp-validation-for="HealthInformation.Weight" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div class="md:col-span-2">
                <label asp-for="HealthInformation.KnownAllergies" class="form-label">Known Allergies</label>
                <textarea asp-for="HealthInformation.KnownAllergies" rows="2" class="form-input" placeholder="e.g. Peanuts, Penicillin (Leave blank if none)"></textarea>
                <span asp-validation-for="HealthInformation.KnownAllergies" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div class="md:col-span-2">
                <label asp-for="HealthInformation.MedicalCondition" class="form-label">Existing Medical Conditions</label>
                <textarea asp-for="HealthInformation.MedicalCondition" rows="2" class="form-input" placeholder="e.g. Asthma, Hypertension"></textarea>
                <span asp-validation-for="HealthInformation.MedicalCondition" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
        </div>
    </div>

    @* Emergency Contact *@

    <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 p-6 sm:p-8 relative z-10">
        <h2 class="text-lg font-extrabold text-slate-900 mb-6 flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center">3</span>
            Emergency Contact
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="EmergencyContact.ContactPersonName" class="form-label">Contact Person Name</label>
                <input asp-for="EmergencyContact.ContactPersonName" type="text" class="form-input" placeholder="e.g. Juan Dela Cruz">
                <span asp-validation-for="EmergencyContact.ContactPersonName" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
            <div>
                <label asp-for="EmergencyContact.EmergencyNumber" class="form-label">Emergency Number</label>
                <input asp-for="EmergencyContact.EmergencyNumber" type="tel" class="form-input" placeholder="e.g. 0919 876 5432">
                <span asp-validation-for="EmergencyContact.EmergencyNumber" class="text-[13px] text-red-600 mt-0.5 font-medium leading-relaxed"></span>
            </div>
        </div>
    </div>

    <div class="flex items-center justify-end gap-4 pt-4 pb-10">
        <a asp-controller="Patients" asp-action="Index" class="px-6 py-3 rounded-xl font-bold text-slate-600 hover:bg-slate-100 transition-colors">Cancel</a>
        <button type="submit" class="px-8 py-3 rounded-xl font-bold text-white bg-emerald-600 hover:bg-emerald-700 shadow-lg shadow-emerald-500/30 hover:shadow-xl hover:shadow-emerald-500/40 hover:-translate-y-0.5 transition-all flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
            Save Record
        </button>
    </div>
   
</form>



@if (TempData["Result"] is not null)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center" x-data="{ statusModal: 'active' }" x-show="statusModal != null">>

        <div
             x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
             class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm"
             x-on:click="statusModal = null"></div>

        <div
             x-transition:enter="transition ease-out duration-300 delay-75" x-transition:enter-start="opacity-0 translate-y-8 scale-95" x-transition:enter-end="opacity-100 translate-y-0 scale-100"
             x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0 scale-100" x-transition:leave-end="opacity-0 translate-y-8 scale-95"
             class="relative bg-white w-full max-w-[340px] mx-4 p-6 rounded-[1.5rem] shadow-2xl border border-slate-100 flex flex-col items-center text-center z-10">

            @if (Convert.ToString(TempData["Result"]) == "Success")
            {
                <template x-init="statusModal = 'success'"></template>
                <template x-if="statusModal === 'success'">
                    <div class="flex flex-col items-center w-full">
                        <div class="w-14 h-14 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center mb-4 border-4 border-white shadow-[0_0_0_4px_rgba(16,185,129,0.15)]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <h3 class="text-[18px] font-extrabold text-slate-900 tracking-tight mb-1.5">Record Saved!</h3>
                        <p class="text-[13px] text-slate-500 mb-6 leading-relaxed">The patient's information has been successfully registered in the system.</p>
                        <a asp-action="Index" x-on:click="statusModal = null;" class="mb-1 w-full py-3 px-4 rounded-[12px] text-[13px] font-bold text-white bg-emerald-600 hover:bg-emerald-700 shadow-[0_8px_15px_rgba(5,150,105,0.2)] transition-all focus:outline-none">
                            Back to Directory
                        </a>
                        <button asp-action="Index" x-on:click="statusModal = null;" class="w-full py-3 px-4 rounded-[12px] text-[13px] font-bold text-slate-600 bg-slate-50 hover:bg-slate-100 transition-colors focus:outline-none">
                            Add New Data
                        </button>
                    </div>
                </template>
                
            } 
            else if (Convert.ToString(TempData["Result"]) == "Validate")
            {
                <template x-init="statusModal = 'validation'"></template>
                <template x-if="statusModal === 'validation'">
                    <div class="flex flex-col items-center w-full">
                        <div class="w-14 h-14 rounded-full bg-red-50 text-red-500 flex items-center justify-center mb-4 border-4 border-white shadow-[0_0_0_4px_rgba(239,68,68,0.15)]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        </div>
                        <h3 class="text-[18px] font-extrabold text-slate-900 tracking-tight mb-1.5">Validation Failed</h3>
                        <p class="text-[13px] text-slate-500 mb-6 leading-relaxed">Please check the form for missing or incorrect information and try again.</p>
                        <button type="button" x-on:click="statusModal = null" class="w-full py-3 px-4 rounded-[12px] text-[13px] font-bold text-slate-600 bg-slate-50 hover:bg-slate-100 transition-colors focus:outline-none">
                            Review Form
                        </button>
                    </div>
                </template>
            }
            else if (Convert.ToString(TempData["Result"]) == "Error")
            {
                <template x-init="statusModal = 'server'"></template>
                <template x-if="statusModal === 'server'">
                    <div class="flex flex-col items-center w-full">
                        <div class="w-14 h-14 rounded-full bg-amber-50 text-amber-500 flex items-center justify-center mb-4 border-4 border-white shadow-[0_0_0_4px_rgba(245,158,11,0.15)]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <h3 class="text-[18px] font-extrabold text-slate-900 tracking-tight mb-1.5">@TempData["ErrorMessage"]</h3>
                        <p class="text-[13px] text-slate-500 mb-6 leading-relaxed">We couldn't connect to the server to save the record. Please try again later.</p>
                        <button x-on:click="statusModal = null" class="w-full py-3 px-4 rounded-[12px] text-[13px] font-bold text-white bg-amber-500 hover:bg-amber-600 shadow-[0_8px_15px_rgba(245,158,11,0.2)] transition-all focus:outline-none">
                            Dismiss
                        </button>
                    </div>
                </template>
            }
        </div>
    </div>
}


@section Scripts {
    <script src="~/assets/js/main.js"></script>
}
