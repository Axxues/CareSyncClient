@model PatientPersonalInformation

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Patients";
}

<div class="mb-8 stagger-1">
    <a asp-controller="Patients" asp-action="Index" class="inline-flex items-center text-sm font-bold text-slate-400 hover:text-emerald-600 transition-colors mb-4">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Directory
    </a>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="flex items-center gap-5">
            <div class="w-20 h-20 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center font-bold text-3xl shadow-sm border-4 border-white">
                MD
            </div>
            <div>
                <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">@Model.FirstName @Model.LastName</h1>
                <p class="text-slate-500 font-medium mt-1">Patient ID: <span class="text-slate-700 font-bold">@Model.Id</span></p>
            </div>
        </div>
        <div class="flex gap-3">
            <a asp-controller="Patients" asp-action="Edit" asp-route-id="@Model.Id" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors flex items-center gap-2 shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                Edit
            </a>
            <button class="px-5 py-2.5 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-700 transition-all shadow-md flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
                Log Checkup
            </button>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <div class="lg:col-span-2 space-y-6 stagger-2">

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm text-center">
                <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Age</p>
                <p class="text-lg font-extrabold text-slate-900 mt-1">@Model.Age Yrs</p>
            </div>
            <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm text-center">
                <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Blood Type</p>
                <p class="text-lg font-extrabold text-red-600 mt-1">@Model.BloodType</p>
            </div>
            <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm text-center">
                <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Registered</p>
                <p class="text-lg font-extrabold text-slate-900 mt-1">@Model.CreatedAt.ToString("MMM dd, yyyy")</p>
            </div>
            <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm text-center">
                <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Updated</p>
                <p class="text-lg font-extrabold text-slate-900 mt-1">@(Model.UpdatedAt != null ? Model.UpdatedAt.Value.ToString("MMM dd, yyyy") : Model.CreatedAt.ToString("MMM dd, yyyy"))</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100">
            <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2 border-b border-slate-100 pb-4">
                <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                Personal Information
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-6">
                <div>
                    <p class="text-sm font-semibold text-slate-400">Date of Birth</p>
                    <p class="text-base font-bold text-slate-800 mt-0.5">@DateTime.Parse(Model.DateofBirth).ToString("MMMM dd, yyyy")</p>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-400">Contact Number</p>
                    <p class="text-base font-bold text-slate-800 mt-0.5">@Model.ContactNumber</p>
                </div>
                
                <div>
                    <p class="text-sm font-semibold text-slate-400">Address</p>
                    <p class="text-base font-bold text-slate-800 mt-0.5">@Model.ResidentialAddress</p>
                </div>

                <div>
                    <p class="text-sm font-semibold text-slate-400">Gender</p>
                    <p class="text-base font-bold text-slate-800 mt-0.5">@Model.Gender</p>
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100">
            <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2 border-b border-slate-100 pb-4">
                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                Health & Emergency
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-6">
                <div>
                    <p class="text-sm font-semibold text-slate-400">Height & Weight</p>
                    <p class="text-base font-bold text-slate-800 mt-0.5">@Model.HealthInformation.Height cm / @Model.HealthInformation.Weight kg</p>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-400">Known Allergies</p>
                    <span class="inline-block px-3 py-1 mt-1 bg-red-50 text-red-600 text-xs font-bold rounded-lg border border-red-100">@Model.HealthInformation.KnownAllergies</span>
                </div>
                <div class="sm:col-span-2">
                    <p class="text-sm font-semibold text-slate-400">Existing Conditions</p>
                    <p class="text-base font-bold text-slate-800 mt-0.5">@Model.HealthInformation.MedicalCondition</p>
                </div>
                <div class="sm:col-span-2 mt-2 pt-4 border-t border-slate-50">
                    <p class="text-sm font-semibold text-slate-400 mb-2">Emergency Contact</p>
                    <div class="flex items-center gap-3 bg-slate-50 p-3 rounded-xl border border-slate-100">
                        <div class="w-10 h-10 bg-slate-200 rounded-full flex items-center justify-center text-slate-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg></div>
                        <div>
                            <p class="font-bold text-slate-900 text-sm">@Model.EmergencyContact.ContactPersonName</p>
                            <p class="text-slate-500 text-xs font-semibold">@Model.EmergencyContact.EmergencyNumber</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100 stagger-3 h-fit flex flex-col max-h-[700px]">

        <h2 class="text-lg font-bold text-slate-900 mb-6 flex items-center justify-between shrink-0">
            Consultation History
            <span class="bg-slate-100 text-slate-600 text-xs py-1 px-2 rounded-lg">3 Records</span>
        </h2>

        <div class="relative flex-1 overflow-y-auto pr-2 custom-scrollbar">

            <div class="relative border-l-2 border-slate-100 ml-3 space-y-8 pb-4">

                @if(Model.ConsultationDetail is not null)
                {
                    @foreach(var consultation in Model.ConsultationDetail)
                    {

                        <div class="relative pl-6">
                            <a asp-controller="Consultations" asp-action="ViewConsultation" asp-route-id="@consultation.Id">
                                <span class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-emerald-500 ring-4 ring-white"></span>
                                <p class="text-xs font-bold text-emerald-600 mb-1">@consultation.CreatedAt.ToString("MMM dd, yyyy")</p>
                                @* <h3 class="text-sm font-bold text-slate-900">Pre-natal Checkup</h3> *@
                                <p class="text-sm text-slate-500 mt-1">@consultation.ConsultationPrescription.Complaint</p>
                                <p class="text-xs text-slate-400 font-semibold mt-2">Attending: Midwife Sarah</p>
                            </a>
                        </div>
                    }
                } else
                {
                    <p>Currently has no consultations.</p>
                }

            </div>
        </div>
    </div>

</div>

