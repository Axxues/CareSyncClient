@model ConsultationDetail

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Consultations";
}

<div class="mb-8 stagger-1">
    <a asp-controller="Consultations" asp-action="Index" class="inline-flex items-center text-sm font-bold text-slate-400 hover:text-emerald-600 transition-colors mb-4">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Logs
    </a>

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Clinical Record</h1>
            <p class="text-slate-500 font-medium mt-1">Consultation Date: <span class="font-bold text-slate-700">@Model.CreatedAt.ToString("MMM dd, yyyy")</span></p>
        </div>
        <button onclick="window.print()" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors shadow-sm flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
            Print Record
        </button>
    </div>
</div>

<div class="space-y-6 stagger-2">

    <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 p-6 flex items-center gap-5">
        <div class="w-16 h-16 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center font-bold text-2xl">@Model.PatientInfo.FirstName[0].ToString()@Model.PatientInfo.LastName[0].ToString()</div>
        <div>
            <h2 class="text-xl font-bold text-slate-900">@Model.PatientInfo.FirstName @Model.PatientInfo.LastName</h2>
            <p class="text-slate-500 text-sm mt-0.5">@Model.PatientInfo.Age yrs, @Model.PatientInfo.Gender • Patient ID: @Model.PatientInfo.Id</p>
        </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-red-50 text-red-500 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
            </div>
            <div>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">BP</p>
                <p class="text-lg font-extrabold text-slate-900">@Model.BloodPressure</p>
            </div>
        </div>
        <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-orange-50 text-orange-500 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            </div>
            <div>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Temp</p>
                <p class="text-lg font-extrabold text-slate-900">@Model.Temperature<span class="text-sm"> °C</span></p>
            </div>
        </div>
        <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Heart</p>
                <p class="text-lg font-extrabold text-slate-900">@Model.HeartRate <span class="text-sm font-medium text-slate-400">bpm</span></p>
            </div>
        </div>
        <div class="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
            </div>
            <div>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-wide">Weight</p>
                <p class="text-lg font-extrabold text-slate-900">@Model.Weight <span class="text-sm font-medium text-slate-400">kg</span></p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 overflow-hidden">
        <div class="p-6 sm:p-8 border-b border-slate-100">
            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">Chief Complaint</h3>
            <p class="text-slate-900 font-medium text-base whitespace-pre-wrap break-words text-gray-700">@Model.ConsultationPrescription.Complaint</p>
        </div>
        <div class="p-6 sm:p-8 border-b border-slate-100 bg-slate-50/50">
            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">Diagnosis / Assessment</h3>
            <p class="text-slate-900 font-medium text-base whitespace-pre-wrap break-words text-gray-700">@Model.ConsultationPrescription.Diagnosis</p>
        </div>
        <div class="p-6 sm:p-8">
            <h3 class="text-sm font-bold text-emerald-600 uppercase tracking-wider mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                Prescription & Plan
            </h3>
            <div class="bg-white border-2 border-dashed border-slate-200 rounded-xl p-5 font-mono text-slate-700 text-sm leading-relaxed whitespace-pre-wrap break-words text-gray-700">
                Rx:<br><br>
                @Model.ConsultationPrescription.Medications
                <br>
                <br>
            </div>
        </div>
    </div>

    <div class="text-right text-sm font-semibold text-slate-400 mt-2">
        Attending Personnel: <span class="text-slate-600 font-bold">Midwife Sarah</span>
    </div>

</div>
