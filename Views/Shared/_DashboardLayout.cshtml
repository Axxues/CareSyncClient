<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Profile - CareSync Enterprise</title>
    <link rel="icon" type="image/x-icon" href="assets/imgs/logo.jpg">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <script defer src="~/assets/js/alpine.min.js"></script>
    <link rel="stylesheet" href="~/assets/css/fonts.css">

    <link rel="stylesheet" href="~/assets/css/style.css">
    @await RenderSectionAsync("LayoutScripts", required: false)

</head>
<body x-data="{ sidebarOpen: false, showDeleteModal: false, loading: false, sidebarOpen: false, logoutModalOpen: false}" class="text-slate-800 overflow-x-hidden">

    <div x-show="sidebarOpen" x-transition.opacity class="fixed inset-0 z-40 bg-slate-900/50 backdrop-blur-sm lg:hidden" x-on:click="sidebarOpen = false"></div>

    <aside :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'" class="fixed inset-y-0 left-0 z-50 w-72 bg-white border-r border-slate-200 transition-transform duration-300 lg:translate-x-0 flex flex-col shadow-2xl lg:shadow-none">

        <div class="h-20 flex items-center px-8 border-b border-slate-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-emerald-50 rounded-xl flex items-center justify-center shadow-sm border border-emerald-100">
                    <img src="~/assets/imgs/logo.jpg" alt="Logo" class="w-6 h-6 object-contain" onerror="this.outerHTML='<svg class=\'w-6 h-6 text-emerald-600\' fill=\'none\' stroke=\'currentColor\' stroke-width=\'2.5\' viewBox=\'0 0 24 24\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' d=\'M12 6v6m0 0v6m0-6h6m-6 0H6\'></path></svg>'">
                </div>
                <span class="font-extrabold text-2xl text-slate-800 tracking-tight">CareSync<span class="text-emerald-500">.</span></span>
            </div>
            <button x-on:click="sidebarOpen = false" class="ml-auto lg:hidden text-slate-400 hover:text-slate-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto" print:hidden">
            <p class="px-4 text-xs font-bold tracking-wider text-slate-400 uppercase mb-4">Main Menu</p>

            @{
                var active = "flex items-center gap-3 px-4 py-3 rounded-xl bg-emerald-50 text-emerald-700 font-bold transition-colors relative group";
                var inactive = "flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 font-semibold hover:bg-slate-50 hover:text-slate-900 transition-colors";
                var highlight = "<div class='absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-8 bg-emerald-500 rounded-r-full'></div>";
            }

            <a asp-controller="Home" asp-action="Dashboard" class="@(ViewData["Title"] == "Dashboard" ? active : inactive)">
                @if (ViewData["Title"] == "Dashboard")
                {
                    @Html.Raw(highlight)
                }
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                Dashboard
            </a>

            <a asp-controller="Patients" asp-action="Index" class="@(ViewData["Title"] == "Patients" ? active : inactive)">
                @if (ViewData["Title"] == "Patients")
                {
                    @Html.Raw(highlight)
                }
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                Patient Directory
            </a>

            <a asp-controller="Consultations" asp-action="Index" class="@(ViewData["Title"] == "Consultations" ? active : inactive)">
                @if (ViewData["Title"] == "Consultations")
                {
                    @Html.Raw(highlight)
                }
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                Consultations
            </a>

            <a asp-controller="Inventory" asp-action="Index" class="@(ViewData["Title"] == "Inventory" ? active : inactive)">
                @if (ViewData["Title"] == "Inventory")
                {
                    @Html.Raw(highlight)
                }
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                Pharmacy Inventory
            </a>

            @* <a asp-controller="Reports" asp-action="Index" class="@(ViewData["Title"] == "Reports" ? active : inactive)">
                @if (ViewData["Title"] == "Reports")
                {
                    @Html.Raw(highlight)
                }
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                FHSIS Reports
            </a> *@

            <p class="px-4 text-xs font-bold tracking-wider text-slate-400 uppercase mb-4 mt-6">Administration</p>

            <a asp-controller="Admin" asp-action="Index" class="@(ViewData["Title"] == "StaffAccounts" ? active : inactive)">
                @if (ViewData["Title"] == "StaffAccounts")
                {
                    @Html.Raw(highlight)
                }
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                Staff Accounts
            </a>
        </nav>

        <div class="p-4 border-t border-slate-100">
            <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-slate-50 border border-slate-100 cursor-pointer hover:bg-slate-100 transition-colors">
                <div class="w-9 h-9 rounded-full bg-emerald-200 text-emerald-700 flex items-center justify-center font-bold text-sm">
                    MS
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-slate-900 truncate">@User.Identity.Name</p>
                    @if (User.IsInRole("Admin"))
                    {
                        <p class="text-xs text-slate-500 truncate">
                            Admin
                        </p>
                    }
                    else if (User.IsInRole("Encoder"))
                    {
                        <p class="text-xs text-slate-500 truncate">
                            Encoder
                        </p>
                    }
                    else if (User.IsInRole("Attending"))
                    {
                        <p class="text-xs text-slate-500 truncate">
                            Attending
                        </p>
                    }
                    
                </div>
                <button x-on:click ="logoutModalOpen = true" class="text-slate-400 hover:text-red-500 transition-colors focus:outline-none" title="Logout">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </button>
            </div>
        </div>
    </aside>

    <div class="lg:pl-72 flex flex-col min-h-screen">

        <header class="h-20 glass-card sticky top-0 z-30 flex items-center justify-between px-6 lg:px-10">
            <div class="flex items-center gap-4">
                <button x-on:click="sidebarOpen = true" class="lg:hidden p-2 rounded-lg bg-slate-50 text-slate-600 hover:bg-slate-100 focus:outline-none">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"></path></svg>
                </button>

                @* <div class="hidden md:flex items-center relative">
                    <svg class="w-5 h-5 absolute left-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <input type="text" placeholder="Search patients, records..." class="pl-10 pr-4 py-2 w-72 bg-slate-50 border border-slate-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all">
                </div> *@
            </div>

            @* <div class="flex items-center gap-4">
                <button class="relative p-2 text-slate-400 hover:text-emerald-600 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    <span class="absolute top-1.5 right-1.5 w-2.5 h-2.5 bg-red-500 border-2 border-white rounded-full"></span>
                </button>
            </div> *@
        </header>

        <main class="flex-1 p-6 lg:p-10 max-w-7xl mx-auto w-full">
            @RenderBody()
        </main>
        <div x-show="logoutModalOpen" style="display: none;" class="fixed inset-0 z-[100] flex items-center justify-center">

            <div x-show="logoutModalOpen"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100"
                 x-transition:leave="transition ease-in duration-200"
                 x-transition:leave-start="opacity-100"
                 x-transition:leave-end="opacity-0"
                 class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm"
                 x-on:click ="logoutModalOpen = false"></div>

            <div x-show="logoutModalOpen"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-y-8 scale-95"
                 x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                 x-transition:leave="transition ease-in duration-150"
                 x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                 x-transition:leave-end="opacity-0 translate-y-8 scale-95"
                 class="relative bg-white w-full max-w-[340px] mx-4 p-6 rounded-[1.5rem] shadow-2xl border border-slate-100 flex flex-col items-center text-center z-10">

                <div class="w-14 h-14 rounded-full bg-red-50 text-red-500 flex items-center justify-center mb-4 border-4 border-white shadow-[0_0_0_4px_rgba(254,226,226,0.5)]">
                    <svg class="w-6 h-6 ml-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                </div>

                <h3 class="text-[18px] font-extrabold text-slate-900 tracking-tight mb-1.5">Ready to Leave?</h3>
                <p class="text-[13px] text-slate-500 mb-6 leading-relaxed px-2">Are you sure you want to log out of your session? You will need to sign in again to access the system.</p>

                <div class="flex gap-3 w-full">
                    <button x-on:click ="logoutModalOpen = false" class="flex-1 py-3 px-4 rounded-[12px] text-[13px] font-bold text-slate-600 bg-slate-50 hover:bg-slate-100 transition-colors focus:outline-none">
                        Cancel
                    </button>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="flex-1 py-3 px-4 rounded-[12px] text-[13px] font-bold text-white bg-red-500 hover:bg-red-600 shadow-[0_8px_15px_rgba(239,68,68,0.2)] hover:shadow-[0_12px_20px_rgba(239,68,68,0.3)] transition-all flex items-center justify-center focus:outline-none">
                            Yes, Log Out
                        </button>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>