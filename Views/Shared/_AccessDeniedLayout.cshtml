<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In - CareSync Enterprise</title>
    <link rel="icon" type="image/x-icon" href="~/assets/imgs/logo.jpg">


    @* <link rel="preload" href="@Context.Request.PathBase/assets/fonts/PlusJakartaSans-Light.woff2" as="font" type="font/woff2" crossorigin="anonymous"> *@
    <link rel="preload" href="@Context.Request.PathBase/assets/fonts/PlusJakartaSans-Normal.woff2" as="font" type="font/woff2" crossorigin="anonymous">
    <link rel="preload" href="@Context.Request.PathBase/assets/fonts/PlusJakartaSans-Bold.woff2" as="font" type="font/woff2" crossorigin="anonymous">
    @* <link rel="preload" href="@Context.Request.PathBase/assets/fonts/PlusJakartaSans-SemiBold.woff2" as="font" type="font/woff2" crossorigin="anonymous">
    <link rel="preload" href="@Context.Request.PathBase/assets/fonts/PlusJakartaSans-UltraBold.woff2" as="font" type="font/woff2" crossorigin="anonymous"> *@


    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/fonts.css" asp-append-version="true">
    <link rel="stylesheet" href="~/assets/css/style.css" asp-append-version="true">
    <script defer src="~/assets/js/alpine.min.js"></script>

    @await RenderSectionAsync("LayoutScripts", required: false)
</head>
<body class="min-h-screen flex items-center justify-center bg-slate-50 relative overflow-hidden p-4"
      x-data="{ count: 10, mouseX: 0, mouseY: 0 }" 
      x-on:mousemove="mouseX = $event.clientX; mouseY = $event.clientY"
      x-init="setInterval(() => { if(count > 0) count--; else window.location.href = '@Url.Action("Index", "Home")' }, 1000)">

    @RenderBody()

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>