@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Reports";
}

@section LayoutScripts {
    <script src="~/assets/js/chart.min.js"></script>
}

<div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8 stagger-1">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">System Analytics</h1>
        <p class="text-slate-500 mt-1 font-medium">Comprehensive data insights for clinic operations.</p>
    </div>
    <a asp-controller="Reports" asp-action="FHSIS" class="inline-flex items-center justify-center gap-2 bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all active:scale-95">
        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        Generate FHSIS Report
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 stagger-2">

    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-200">
        <div class="flex items-center justify-between mb-6">
            <h3 class="font-extrabold text-slate-900">Patient Volume (Monthly)</h3>
            <span class="text-xs font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded-lg">+12% vs last year</span>
        </div>
        <div class="h-64">
            <canvas id="reportingChart"></canvas>
        </div>
    </div>

    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-200">
        <h3 class="font-extrabold text-slate-900 mb-6">Demographic Breakdown</h3>
        <div class="space-y-4">
            <div>
                <div class="flex justify-between text-sm font-bold mb-1.5">
                    <span class="text-slate-500">Maternal Care</span>
                    <span class="text-slate-900">45%</span>
                </div>
                <div class="w-full bg-slate-100 h-2.5 rounded-full overflow-hidden">
                    <div class="bg-emerald-500 h-full w-[45%] rounded-full"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm font-bold mb-1.5">
                    <span class="text-slate-500">Child Immunization</span>
                    <span class="text-slate-900">30%</span>
                </div>
                <div class="w-full bg-slate-100 h-2.5 rounded-full overflow-hidden">
                    <div class="bg-blue-500 h-full w-[30%] rounded-full"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between text-sm font-bold mb-1.5">
                    <span class="text-slate-500">General Consultation</span>
                    <span class="text-slate-900">25%</span>
                </div>
                <div class="w-full bg-slate-100 h-2.5 rounded-full overflow-hidden">
                    <div class="bg-amber-500 h-full w-[25%] rounded-full"></div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/assets/js/main.js"></script>
}
    
