@model DashboardViewData
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Dashboard";
}

@section LayoutScripts {
    <script src="~/assets/js/chart.min.js"></script>
}

<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 stagger-1">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">System Overview</h1>
        <p class="text-slate-500 mt-1 font-medium">Here's what's happening at Brgy. Garcia Health Center today.</p>
    </div>
    <a asp-controller="Patients" asp-action="Create" class="inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-6 rounded-xl shadow-[0_8px_15px_rgba(5,150,105,0.2)] hover:shadow-[0_12px_20px_rgba(5,150,105,0.3)] transition-all hover:-translate-y-0.5">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
        New Patient Record
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8 stagger-2">

    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100 hover:shadow-md transition-shadow relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:scale-110 group-hover:-rotate-12 transition-transform duration-500">
            <svg class="w-24 h-24 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path></svg>
        </div>
        <div class="flex items-center gap-4 relative z-10">
            <div class="w-12 h-12 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-slate-500">Total Registered Patients</p>
                <h3 class="text-3xl font-extrabold text-slate-900 mt-1">@Model.TotalRegisteredPatients</h3>
            </div>
        </div>
        @* <div class="mt-4 flex items-center text-sm font-medium text-emerald-600 bg-emerald-50 inline-flex px-2 py-1 rounded-md relative z-10">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            +12% from last month
        </div> *@
    </div>

    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100 hover:shadow-md transition-shadow relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:scale-110 transition-transform duration-500">
            <svg class="w-24 h-24 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path></svg>
        </div>
        <div class="flex items-center gap-4 relative z-10">
            <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-slate-500">Consultations Today</p>
                <h3 class="text-3xl font-extrabold text-slate-900 mt-1">@Model.ConsultationsToday</h3>
            </div>
        </div>
        @* <div class="mt-4 flex items-center text-sm font-medium text-slate-500 relative z-10">
            <span class="text-blue-600 font-bold mr-1">5</span> waiting in queue
        </div> *@
    </div>

    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100 hover:shadow-md transition-shadow relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:scale-110 transition-transform duration-500">
            <svg class="w-24 h-24 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
        </div>
        <div class="flex items-center gap-4 relative z-10">
            <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center text-red-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-slate-500">Low Stock Medicines</p>
                <h3 class="text-3xl font-extrabold text-slate-900 mt-1">@Model.LowStockMedicines</h3>
            </div>
        </div>
        <a asp-controller="Inventory" asp-action="Index" class="mt-4 flex items-center text-sm font-medium text-red-600 bg-red-50 inline-flex px-2 py-1 rounded-md relative z-10 hover:bg-red-100 cursor-pointer transition-colors">
            View Inventory Alerts &rarr;
        </a>
    </div>

</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 stagger-3">

    <div class="lg:col-span-2 bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-lg font-bold text-slate-900">Weekly Patient Registration</h2>
            <button class="p-1.5 hover:bg-slate-50 rounded-lg text-slate-400 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"></path></svg>
            </button>
        </div>

        <div class="relative h-[300px] w-full">
            @* <canvas id="patientsChart"></canvas> *@
            Chart to be published soon
        </div>
    </div>

    <div class="bg-white p-6 rounded-[1.5rem] shadow-sm border border-slate-100">
        <h2 class="text-lg font-bold text-slate-900 mb-6">Recent Consultations</h2>

        <div class="space-y-5">
            @foreach(var consultation in Model.RecentConsultations)
            {
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 font-bold shrink-0">
                        @consultation.PatientInfo.FirstName[0].ToString()@consultation.PatientInfo.LastName[0].ToString()
                    </div>
                    <div>
                        <p class="text-sm font-bold text-slate-900">@consultation.PatientInfo.FirstName @consultation.PatientInfo.LastName</p>
                        <p class="text-xs text-slate-500 mt-0.5">@consultation.ConsultationPrescription.Complaint</p>
                        <p class="text-[11px] text-emerald-600 font-semibold mt-1">@consultation.CreatedAt.ToString("MMMM dd, yyyy")</p>
                    </div>
                </div>
            }
            
        </div>

        <a asp-controller="Consultations"
           asp-action="Index"
           class="w-full mt-6 py-2.5 text-sm font-bold text-emerald-600 bg-emerald-50 rounded-xl hover:bg-emerald-100 transition-colors flex justify-center items-center">
            View All Records
        </a>
    </div>

</div>

        
@section Scripts {
    <script src="~/assets/js/main.js"></script>
}
    
